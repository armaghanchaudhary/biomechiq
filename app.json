{
  "expo": {
    "name": "BiomechIQ",
    "slug": "biomechiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "biomechiq",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080B0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.biomechiq.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "BiomechIQ needs camera access to analyze your movement.",
        "NSMicrophoneUsageDescription": "Microphone access is needed for video session recording.",
        "NSPhotoLibraryUsageDescription": "BiomechIQ saves session recordings to your photo library."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080B0F"
      },
      "package": "com.biomechiq.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "BiomechIQ needs camera access to analyze your movement.",
          "enableMicrophonePermission": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00E5FF"
        }
      ],
      [
        "react-native-mediapipe-posedetection",
        {
          "assetsPaths": ["./assets/models/"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "71f951f1-1b3c-42b4-9bde-0bfae044f5c1"
      }
    },
    "owner": "armaghan.dev"
  }
}
