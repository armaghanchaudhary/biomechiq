{
  "name": "biomechiq",
  "version": "1.0.0",
  "description": "Cross-platform sports biomechanics analyzer — Web, iOS, Android",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "build:web": "expo export --platform web",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.18",
    "@sentry/react-native": "~6.14.0",
    "@shopify/react-native-skia": "v2.0.0-next.4",
    "@supabase/supabase-js": "^2.47.0",
    "@tanstack/react-query": "^5.60.0",
    "date-fns": "^4.1.0",
    "expo": "^53.0.0",
    "expo-audio": "~0.4.9",
    "expo-blur": "~14.1.5",
    "expo-camera": "~16.1.11",
    "expo-constants": "~17.1.8",
    "expo-device": "~7.1.4",
    "expo-file-system": "~18.1.11",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-speech": "~13.1.7",
    "expo-status-bar": "~2.2.3",
    "expo-video": "~2.2.2",
    "lodash": "^4.17.21",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-fast-tflite": "^3.0.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-mediapipe-posedetection": "^0.4.0",
    "react-native-purchases": "^8.3.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-vision-camera": "~4.7.0",
    "react-native-worklets-core": "^1.3.3",
    "victory-native": "^41.0.0",
    "vision-camera-resize-plugin": "^3.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "@types/lodash": "^4.17.0",
    "typescript": "~5.8.3",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "prettier": "^3.4.0"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": ["react-native-fast-tflite", "react-native-mediapipe-posedetection", "vision-camera-resize-plugin"]
      }
    }
  }
}
